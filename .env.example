# ── Slack ──────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_USER_ID=U0123456789          # Your personal Slack user ID
SLACK_CHANNEL_ID=C0123456789       # Channel where the bot posts the daily prompt

# ── Clockify ───────────────────────────────────────────────────────────
CLOCKIFY_API_KEY=your-clockify-api-key
CLOCKIFY_WORKSPACE_ID=your-workspace-id
CLOCKIFY_MEETINGS=                 # Project ID for calendar meetings
CLOCKIFY_PUBLICHOLIDAY=            # Project ID for public holidays
# Add one CLOCKIFY_<NAME> var per project — Gemini auto-assigns tasks using the name as a label.
# The first var alphabetically is used as fallback when no project matches.
# Example:
CLOCKIFY_INFRASTRUCTURE=project-id-here
CLOCKIFY_NHLMIS=project-id-here
CLOCKIFY_SHELFLIFE=project-id-here
# Optional keyword hints — Gemini uses these to match tasks to the right project.
# Pattern: CLOCKIFY_<NAME>_KEYWORDS=comma-separated phrases
CLOCKIFY_INFRASTRUCTURE_KEYWORDS=staging release, prod release, deployment, hotfix, infrastructure
# Optional: override with an explicit JSON map instead of individual vars above
# CLOCKIFY_PROJECTS={"QA Testing": "id1", "Development": "id2"}

# ── Google Calendar ────────────────────────────────────────────────────
# Paste the JSON printed by setup_google_auth.py (all on one line)
GOOGLE_TOKEN_JSON={"token":"...","refresh_token":"...","token_uri":"...","client_id":"...","client_secret":"...","scopes":["..."]}

# ── Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── App ────────────────────────────────────────────────────────────────
TIMEZONE=Africa/Lagos              # West Africa Time (UTC+1). See: pytz.all_timezones
COUNTRY_CODE=NG                    # ISO country code for public holidays (e.g. NG, GH, US, GB)
PORT=3000                          # Railway sets this automatically
