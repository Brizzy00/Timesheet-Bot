# ── Slack ──────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_USER_ID=U0123456789          # Your personal Slack user ID

# ── Clockify ───────────────────────────────────────────────────────────
CLOCKIFY_API_KEY=your-clockify-api-key
CLOCKIFY_WORKSPACE_ID=your-workspace-id
CLOCKIFY_DEFAULT_PROJECT_ID=       # Optional: default project for tasks
CLOCKIFY_MEETINGS_PROJECT_ID=      # Optional: separate project for meetings

# ── Google Calendar ────────────────────────────────────────────────────
# Paste the JSON printed by setup_google_auth.py (all on one line)
GOOGLE_TOKEN_JSON={"token":"...","refresh_token":"...","token_uri":"...","client_id":"...","client_secret":"...","scopes":["..."]}

# ── Anthropic ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key

# ── App ────────────────────────────────────────────────────────────────
TIMEZONE=America/New_York          # Your local timezone
PORT=3000                          # Railway sets this automatically
